# AI Writer Pro - Environment Variables
# Copy this to .env and fill in at least one API key

# Server
PORT=3000

# === DeepSeek (推荐首选！新用户注册即开，送500万token免费) ===
# 注册: https://platform.deepseek.com → API Keys
DEEPSEEK_API_KEY=sk-...

# === 备选 ===
# Google Gemini (免费额度大): https://aistudio.google.com/apikey
# GEMINI_API_KEY=...
# OpenAI: https://platform.openai.com
# OPENAI_API_KEY=sk-...
# Anthropic: https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...

# Master API key for your extension users
MASTER_API_KEY=aiw_master_change_me

