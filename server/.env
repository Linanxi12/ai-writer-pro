# AI Writer Pro - Environment Variables
PORT=3000

# === DeepSeek (推荐！国内直接注册，新用户送500万token) ===
# 1. 打开 https://platform.deepseek.com
# 2. 注册 → API Keys → 创建 key
# 3. 复制 sk-... 粘贴到下面
DEEPSEEK_API_KEY=sk-eec74ed1bb674fcc94d7e54c577d96cb

# === 备选方案 ===
# Google Gemini (免费额度大): https://aistudio.google.com/apikey
# GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# OpenAI: https://platform.openai.com
# OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# Anthropic (暂不开放新用户): https://console.anthropic.com
# ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# 管理员密钥（自己随便设一个长的）
MASTER_API_KEY=aiw_dev_change_me_to_random_string

# Stripe（收钱时再配）
# STRIPE_SECRET_KEY=sk_live_...

# === Lemon Squeezy 收款（推荐！无需海外公司） ===
# 1. 注册 https://app.lemonsqueezy.com
# 2. Settings → API → 生成 API Key
# 3. Store 页面 → 复制 Store ID
# 4. Products → 创建 Pro ($9) 和 Business ($29) → 复制 Variant ID
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_PRO_VARIANT=
LEMON_SQUEEZY_BUSINESS_VARIANT=
# Webhook: Dashboard → Settings → Webhooks → 填入 https://你的域名/v1/webhook
LEMON_SQUEEZY_WEBHOOK_SECRET=
# 也可以直接用 Lemon Squeezy 的直链（Dashboard → Products → Share）
LEMON_SQUEEZY_PRO_LINK=https://xiaoqi.lemonsqueezy.com/checkout/buy/a9844e25-dc1f-483f-8207-0dec1e5afde2
LEMON_SQUEEZY_BUSINESS_LINK=https://xiaoqi.lemonsqueezy.com/checkout/buy/0ed4e5bd-ce8a-4823-8715-0fa798825c6c
